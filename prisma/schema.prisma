generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TransactionStatus {
  draft
  completed
  cancelled
}

enum PaymentMethod {
  cash
  gcash
}

enum DiscountType {
  fixed
  percentage
}

enum MovementType {
  sale_deduction
  manual_adjustment
  purchase_receipt
}

enum UserRole {
  owner
  staff

  @@map("user_role")
}

enum UserDepartment {
  physical_dept
  design_dept
  dev_dept

  @@map("user_department")
}

// ─── Auth / Access ────────────────────────────────────────────────────────────

model AllowedUser {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String           @unique @db.Text
  name       String?          @db.Text
  role       UserRole         @default(staff)
  department UserDepartment?
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@map("allowed_users")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String  @db.Text
  unit              String  @default("sheet") @db.Text
  stockOnHand       Decimal @default(0) @map("stock_on_hand") @db.Decimal(10, 2)
  lowStockThreshold Decimal @default(0) @map("low_stock_threshold") @db.Decimal(10, 2)
  costPerUnit       Decimal @default(0) @map("cost_per_unit") @db.Decimal(10, 2)
  sellingPrice      Decimal @default(0) @map("selling_price") @db.Decimal(10, 2)
  isActive          Boolean @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  inventoryMovements InventoryMovement[]
  materialPrices     ServiceMaterialPrice[]
  costProfiles       CostProfile[]

  @@map("inventory_items")
}

model InventoryMovement {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryItemId String       @map("inventory_item_id") @db.Uuid
  transactionId   String?      @map("transaction_id") @db.Uuid
  movementType    MovementType @map("movement_type")
  quantityDelta   Decimal      @map("quantity_delta") @db.Decimal(10, 2)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  inventoryItem InventoryItem      @relation(fields: [inventoryItemId], references: [id])
  transaction   SalesTransaction?  @relation(fields: [transactionId], references: [id])

  @@map("inventory_movements")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model ServiceCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.Text
  department String   @default("physical_dept") @db.Text
  icon       String   @default("") @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  services Service[]

  @@map("service_categories")
}

model Service {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.Text
  categoryId  String?   @map("category_id") @db.Uuid
  description String    @default("") @db.Text
  basePrice   Decimal   @default(0) @map("base_price") @db.Decimal(10, 2)
  icon        String    @default("") @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  category       ServiceCategory?      @relation(fields: [categoryId], references: [id])
  materialPrices ServiceMaterialPrice[]
  costProfiles   CostProfile[]

  @@map("services")
}

model AddOn {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.Text
  department String   @default("physical_dept") @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  addOnEntries SalesAddOnEntry[]

  @@map("add_ons")
}

model ServiceMaterialPrice {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId         String  @map("service_id") @db.Uuid
  inventoryItemId   String  @map("inventory_item_id") @db.Uuid
  suggestedUnitPrice Decimal @map("suggested_unit_price") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  service       Service       @relation(fields: [serviceId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("service_material_prices")
}

// ─── Sales ────────────────────────────────────────────────────────────────────

model SalesTransaction {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionNumber BigInt            @unique @map("transaction_number")
  status            TransactionStatus @default(draft)
  cashierName       String            @map("cashier_name") @db.Text
  deliveryEnabled   Boolean           @default(false) @map("delivery_enabled")
  customerName      String?           @map("customer_name") @db.Text
  deliveryAddress   String?           @map("delivery_address") @db.Text
  dropOffLocation   String?           @map("drop_off_location") @db.Text
  deliveryFee       Decimal           @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discountType      DiscountType?     @map("discount_type")
  discountValue     Decimal?          @map("discount_value") @db.Decimal(10, 2)
  draftPayload      Json              @default("{}") @map("draft_payload") @db.JsonB
  subtotal          Decimal           @default(0) @db.Decimal(10, 2)
  finalTotal        Decimal           @default(0) @map("final_total") @db.Decimal(10, 2)
  paymentMethod     PaymentMethod?    @map("payment_method")
  cashReceived      Decimal?          @map("cash_received") @db.Decimal(10, 2)
  gcashAmountPaid   Decimal?          @map("gcash_amount_paid") @db.Decimal(10, 2)
  changeDue         Decimal?          @map("change_due") @db.Decimal(10, 2)
  completedAt       DateTime?         @map("completed_at") @db.Timestamptz
  cancelledAt       DateTime?         @map("cancelled_at") @db.Timestamptz
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  department        String            @default("physical_dept") @db.Text

  serviceLines   SalesServiceLine[]
  inventoryMovements InventoryMovement[]
  contributors   TransactionContributor[]

  @@map("sales_transactions")
}

model SalesServiceLine {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  serviceId     String   @map("service_id") @db.Uuid
  serviceName   String   @map("service_name") @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  transaction   SalesTransaction      @relation(fields: [transactionId], references: [id])
  materialEntries SalesMaterialEntry[]

  @@map("sales_service_lines")
}

model SalesMaterialEntry {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceLineId   String  @map("service_line_id") @db.Uuid
  inventoryItemId String  @map("inventory_item_id") @db.Uuid
  materialName    String  @map("material_name") @db.Text
  quantity        Decimal @db.Decimal(10, 2)
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  serviceLine  SalesServiceLine   @relation(fields: [serviceLineId], references: [id])
  addOnEntries  SalesAddOnEntry[]

  @@map("sales_material_entries")
}

model SalesAddOnEntry {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  materialEntryId String  @map("material_entry_id") @db.Uuid
  addOnId         String  @map("add_on_id") @db.Uuid
  addOnName       String  @map("add_on_name") @db.Text
  quantity        Decimal @db.Decimal(10, 2)
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  materialEntry SalesMaterialEntry @relation(fields: [materialEntryId], references: [id])
  addOn         AddOn              @relation(fields: [addOnId], references: [id])

  @@map("sales_add_on_entries")
}

// ─── Staff ────────────────────────────────────────────────────────────────────

model StaffMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.Text
  department String   @default("physical_dept") @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  sessions StaffSession[]
  contributors TransactionContributor[]
  distributionPayouts DistributionPayout[]

  @@map("staff_members")
}

model StaffSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staffMemberId  String?   @map("staff_member_id") @db.Uuid
  staffName      String    @map("staff_name") @db.Text
  department     String    @default("physical_dept") @db.Text
  timeIn         DateTime  @default(now()) @map("time_in") @db.Timestamptz
  timeOut        DateTime? @map("time_out") @db.Timestamptz
  autoLoggedOut  Boolean   @default(false) @map("auto_logged_out")
  note           String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id])

  @@index([staffMemberId, timeIn])
  @@index([timeOut, timeIn])
  @@index([department])
  @@map("staff_sessions")
}

model TransactionContributor {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId  String   @map("transaction_id") @db.Uuid
  staffMemberId  String   @map("staff_member_id") @db.Uuid
  staffName      String   @map("staff_name") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  staffMember StaffMember      @relation(fields: [staffMemberId], references: [id])

  @@index([transactionId])
  @@index([staffMemberId])
  @@map("transaction_contributors")
}

model DistributionPayout {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staffMemberId  String?   @map("staff_member_id") @db.Uuid
  staffName      String?   @map("staff_name") @db.Text
  department     String    @db.Text
  periodFrom     DateTime  @map("period_from") @db.Timestamptz
  periodTo       DateTime  @map("period_to") @db.Timestamptz
  amount         Decimal   @default(0) @db.Decimal(10, 2)
  given          Boolean   @default(false)
  givenAt        DateTime? @map("given_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id])

  @@unique([department, periodFrom, periodTo])
  @@index([staffMemberId])
  @@index([periodFrom, periodTo])
  @@index([department])
  @@map("distribution_payouts")
}

// ─── Costing ──────────────────────────────────────────────────────────────────

model CostProfile {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId       String  @map("service_id") @db.Uuid
  inventoryItemId String  @map("inventory_item_id") @db.Uuid
  materialCost    Decimal @default(0) @map("material_cost") @db.Decimal(10, 2)
  inkCost         Decimal @default(0) @map("ink_cost") @db.Decimal(10, 2)
  spoilageRate    Decimal @default(0) @map("spoilage_rate") @db.Decimal(5, 2)
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  service       Service       @relation(fields: [serviceId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quoteLineItems QuoteLineItem[]

  @@unique([serviceId, inventoryItemId])
  @@map("cost_profiles")
}

model Quote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.Text
  notes     String?  @db.Text
  createdBy String   @map("created_by") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lineItems QuoteLineItem[]

  @@map("quotes")
}

model QuoteLineItem {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId          String  @map("quote_id") @db.Uuid
  costProfileId    String  @map("cost_profile_id") @db.Uuid
  quantity         Decimal @default(1) @db.Decimal(10, 2)
  snapMaterialCost Decimal @default(0) @map("snap_material_cost") @db.Decimal(10, 2)
  snapInkCost      Decimal @default(0) @map("snap_ink_cost") @db.Decimal(10, 2)
  snapOverheadCost Decimal @default(0) @map("snap_overhead_cost") @db.Decimal(10, 2)
  snapSpoilageRate Decimal @default(0) @map("snap_spoilage_rate") @db.Decimal(5, 2)
  snapSellingPrice Decimal @default(0) @map("snap_selling_price") @db.Decimal(10, 2)
  overridePrice    Decimal? @map("override_price") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  sortOrder        Int     @default(0) @map("sort_order")

  quote        Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  costProfile  CostProfile @relation(fields: [costProfileId], references: [id])

  @@map("quote_line_items")
}

model AppSetting {
  key       String   @id @db.Text
  value     Json     @db.JsonB
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("app_settings")
}
